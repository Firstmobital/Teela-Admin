# ===== FRONTEND ENVIRONMENT VARIABLES (Public, safe to expose) =====

# Supabase Configuration (get from Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay Configuration (get from Razorpay Dashboard > Settings > API Keys)
# ⚠️  ONLY the Key ID. Secret key MUST stay in Supabase Edge Function secrets.
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ===== BACKEND / EDGE FUNCTION SECRETS (NEVER expose to frontend) =====
# Set these ONLY in Supabase Dashboard > Settings > Secrets
# - SUPABASE_SERVICE_ROLE_KEY (for Edge Functions to access Supabase)
# - RAZORPAY_SECRET_KEY (for payment verification in Edge Functions)
# - EZEE_API_KEY (for PMS/POS integration)
# - FCM_SERVER_KEY (for push notifications to staff)

# Optional integration secrets for edge functions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_PROVIDER_PUBLIC_KEY=
